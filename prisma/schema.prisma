generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  owner
  admin
  viewer
}

enum GoalType {
  pageview
  event
}

enum GoalMatchType {
  exact
  prefix
}

enum FunnelMode {
  sequential
  strict
}

enum NotificationChannelType {
  email
  webhook
}

enum IncidentStatus {
  open
  resolved
}

enum InsightSeverity {
  info
  warning
  critical
}

enum EnvironmentKind {
  production
  staging
  development
  other
}

enum ServiceKind {
  web
  api
  worker
  database
  job
  other
}

enum MonitorType {
  http
  heartbeat
  ssl_expiry
  domain_expiry
}

enum DeploymentStatus {
  started
  succeeded
  failed
  rolled_back
}

enum BriefGenerator {
  template
  ai
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String
  passwordHash     String?
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      OrgMembership[]
  accounts         Account[]
  agentTokens      AgentToken[]      @relation("AgentTokenCreator")
  shareLinks       ShareLink[]       @relation("ShareLinkCreator")
  scheduledReports ScheduledReport[] @relation("ScheduledReportCreator")
  teamInvites      TeamInvite[]      @relation("TeamInviteCreator")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  type              String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Organization {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  members              OrgMembership[]
  sites                Site[]
  notificationChannels NotificationChannel[]
  statusPages          StatusPage[]
  agentTokens          AgentToken[]
  agentAuditLogs       AgentAuditLog[]
  shareLinks           ShareLink[]
  scheduledReports     ScheduledReport[]
  invites              TeamInvite[]
  projects             Project[]
  dailyBriefs          DailyBrief[]
  timezone             String                @default("UTC")
  dailyBriefEnabled    Boolean               @default(true)
  dailyBriefHour       Int                   @default(8)
}

model OrgMembership {
  id     String       @id @default(uuid())
  role   OrgRole      @default(viewer)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId  String

  @@unique([userId, orgId])
  @@index([orgId])
}

model Site {
  id               String                @id @default(uuid())
  name             String
  domain           String
  token            String                @unique
  active           Boolean               @default(true)
  collectWebVitals Boolean               @default(false)
  org              Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId            String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  pageviews        Pageview[]
  events           Event[]
  uptimeChecks     UptimeCheck[]
  goals            Goal[]
  funnels          Funnel[]
  alertRules       AlertRule[]
  incidents        Incident[]
  statusComponents StatusPageComponent[]
  webVitals        WebVital[]
  insights         Insight[]
  agentTokens      AgentToken[]
  agentAuditLogs   AgentAuditLog[]
  shareLinks       ShareLink[]
  scheduledReports ScheduledReport[]
  service          Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceId        String?

  @@index([orgId])
  @@index([serviceId])
}

model Pageview {
  id          String   @id @default(uuid())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  visitId     String?
  hostname    String   @default("")
  pathname    String
  referrer    String   @default("")
  utmSource   String   @default("")
  utmMedium   String   @default("")
  utmCampaign String   @default("")
  browser     String   @default("")
  os          String   @default("")
  device      String   @default("")
  country     String   @default("")
  language    String   @default("")
  timestamp   DateTime @default(now())

  @@index([siteId, timestamp])
  @@index([siteId, visitId, timestamp])
  @@index([siteId, pathname])
  @@index([siteId, referrer])
}

model Event {
  id              String   @id @default(uuid())
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId          String
  visitId         String?
  name            String
  properties      Json     @default("{}")
  hostname        String   @default("")
  pathname        String   @default("")
  referrer        String   @default("")
  utmSource       String   @default("")
  utmMedium       String   @default("")
  utmCampaign     String   @default("")
  browser         String   @default("")
  os              String   @default("")
  device          String   @default("")
  country         String   @default("")
  language        String   @default("")
  revenueValue    Decimal? @db.Decimal(12, 2)
  revenueCurrency String?
  orderId         String?
  timestamp       DateTime @default(now())

  @@unique([siteId, name, orderId])
  @@index([siteId, timestamp])
  @@index([siteId, visitId, timestamp])
  @@index([siteId, name])
  @@index([siteId, orderId])
}

model UptimeCheck {
  id           String   @id @default(uuid())
  site         Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId       String?
  monitor      Monitor? @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  monitorId    String?
  statusCode   Int?
  responseTime Int?
  isUp         Boolean
  error        String?
  metadata     Json     @default("{}")
  checkedAt    DateTime @default(now())

  @@index([siteId, checkedAt])
  @@index([monitorId, checkedAt])
}

model NotificationChannel {
  id         String                  @id @default(uuid())
  org        Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  type       NotificationChannelType
  name       String
  target     String
  enabled    Boolean                 @default(true)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  alertRules AlertRule[]

  @@index([orgId])
}

model AlertRule {
  id                    String              @id @default(uuid())
  site                  Site?               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId                String?
  monitor               Monitor?            @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  monitorId             String?
  notificationChannel   NotificationChannel @relation(fields: [notificationChannelId], references: [id], onDelete: Cascade)
  notificationChannelId String
  enabled               Boolean             @default(true)
  consecutiveFailures   Int                 @default(2)
  recoveryChecks        Int                 @default(1)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([siteId])
  @@index([monitorId])
  @@index([notificationChannelId])
}

model Incident {
  id             String         @id @default(uuid())
  site           Site?          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId         String?
  monitor        Monitor?       @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  monitorId      String?
  status         IncidentStatus @default(open)
  title          String
  description    String?
  startedAt      DateTime       @default(now())
  resolvedAt     DateTime?
  lastNotifiedAt DateTime?

  @@index([siteId, status])
  @@index([siteId, startedAt])
  @@index([monitorId, status])
  @@index([monitorId, startedAt])
}

model StatusPage {
  id          String                @id @default(uuid())
  org         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  slug        String                @unique
  name        String
  description String?
  enabled     Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  components  StatusPageComponent[]

  @@index([orgId])
}

model StatusPageComponent {
  id           String     @id @default(uuid())
  statusPage   StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  statusPageId String
  site         Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId       String?
  service      Service?   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId    String?
  name         String
  sortOrder    Int        @default(0)

  @@unique([statusPageId, siteId])
  @@unique([statusPageId, serviceId])
  @@index([siteId])
  @@index([serviceId])
}

model Goal {
  id            String        @id @default(uuid())
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId        String
  name          String
  type          GoalType
  matchType     GoalMatchType @default(exact)
  path          String?
  eventName     String?
  propertyKey   String?
  propertyValue String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  funnelSteps   FunnelStep[]

  @@index([siteId])
}

model Funnel {
  id        String       @id @default(uuid())
  site      Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String
  name      String
  mode      FunnelMode   @default(sequential)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  steps     FunnelStep[]

  @@index([siteId])
}

model FunnelStep {
  id       String @id @default(uuid())
  funnel   Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  funnelId String
  goal     Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  goalId   String
  position Int

  @@unique([funnelId, position])
  @@index([goalId])
}

model WebVital {
  id        String   @id @default(uuid())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String
  visitId   String?
  name      String
  value     Float
  rating    String
  hostname  String   @default("")
  pathname  String   @default("")
  browser   String   @default("")
  os        String   @default("")
  device    String   @default("")
  country   String   @default("")
  language  String   @default("")
  timestamp DateTime @default(now())

  @@index([siteId, timestamp])
  @@index([siteId, name, timestamp])
}

model Insight {
  id             String          @id @default(uuid())
  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId         String
  type           String
  severity       InsightSeverity @default(info)
  title          String
  body           String
  evidence       Json            @default("{}")
  impact         String?
  recommendation String?
  snoozedUntil   DateTime?
  completedAt    DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime        @default(now())

  @@index([siteId, createdAt])
  @@index([siteId, dismissedAt])
  @@index([siteId, completedAt])
  @@index([siteId, snoozedUntil])
}

model Project {
  id             String          @id @default(uuid())
  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId          String
  name           String
  slug           String
  description    String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  environments   Environment[]
  deployments    Deployment[]
  agentTokens    AgentToken[]
  agentAuditLogs AgentAuditLog[]

  @@unique([orgId, slug])
  @@index([orgId, active])
}

model Environment {
  id          String          @id @default(uuid())
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  slug        String
  kind        EnvironmentKind @default(production)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  services    Service[]
  deployments Deployment[]

  @@unique([projectId, slug])
  @@index([projectId, kind])
}

model Service {
  id               String                @id @default(uuid())
  environment      Environment           @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  environmentId    String
  name             String
  slug             String
  kind             ServiceKind           @default(web)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  sites            Site[]
  monitors         Monitor[]
  deployments      Deployment[]
  statusComponents StatusPageComponent[]

  @@unique([environmentId, slug])
  @@index([environmentId, kind])
}

model Monitor {
  id              String        @id @default(uuid())
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId       String
  name            String
  type            MonitorType
  enabled         Boolean       @default(true)
  intervalSeconds Int           @default(300)
  graceSeconds    Int           @default(60)
  timeoutMs       Int           @default(10000)
  config          Json          @default("{}")
  secretHash      String?       @unique
  secretPrefix    String?
  lastSeenAt      DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  checks          UptimeCheck[]
  incidents       Incident[]
  alertRules      AlertRule[]

  @@index([serviceId, enabled])
  @@index([enabled, nextRunAt])
  @@index([type, lastSeenAt])
}

model Deployment {
  id            String           @id @default(uuid())
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  environment   Environment      @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  environmentId String
  service       Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceId     String?
  commitSha     String?
  version       String?
  status        DeploymentStatus @default(succeeded)
  source        String           @default("manual")
  url           String?
  metadata      Json             @default("{}")
  deployedAt    DateTime         @default(now())
  createdAt     DateTime         @default(now())

  @@index([projectId, deployedAt])
  @@index([environmentId, deployedAt])
  @@index([serviceId, deployedAt])
}

model DailyBrief {
  id          String         @id @default(uuid())
  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  localDate   DateTime       @db.Date
  periodStart DateTime
  periodEnd   DateTime
  summary     String
  evidence    Json           @default("{}")
  generator   BriefGenerator @default(template)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([orgId, localDate])
  @@index([orgId, periodEnd])
}

model ShareLink {
  id          String       @id @default(uuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  name        String
  token       String       @unique
  reports     String[]
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdBy   User?        @relation("ShareLinkCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId])
  @@index([siteId])
  @@index([revokedAt])
  @@index([expiresAt])
}

model ScheduledReport {
  id          String                  @id @default(uuid())
  org         Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  site        Site                    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String
  name        String
  reports     String[]
  frequency   String                  @default("weekly")
  channelType NotificationChannelType
  target      String
  enabled     Boolean                 @default(true)
  nextRunAt   DateTime?
  lastSentAt  DateTime?
  createdBy   User?                   @relation("ScheduledReportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([orgId])
  @@index([siteId])
  @@index([enabled, nextRunAt])
}

model TeamInvite {
  id          String       @id @default(uuid())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  email       String
  role        OrgRole      @default(viewer)
  token       String       @unique
  status      String       @default("pending")
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdBy   User?        @relation("TeamInviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId])
  @@index([email])
  @@index([status])
}

model AgentToken {
  id          String          @id @default(uuid())
  org         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  site        Site?           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String?
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  name        String
  tokenHash   String          @unique
  tokenPrefix String
  scopes      String[]
  role        OrgRole         @default(viewer)
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdBy   User?           @relation("AgentTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  auditLogs   AgentAuditLog[]

  @@index([orgId])
  @@index([siteId])
  @@index([projectId])
  @@index([tokenPrefix])
  @@index([revokedAt])
  @@index([expiresAt])
}

model AgentAuditLog {
  id        String        @id @default(uuid())
  org       Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  orgId     String?
  site      Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteId    String?
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?
  token     AgentToken?   @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  tokenId   String?
  action    String
  outcome   String
  toolName  String?
  scopes    String[]
  ipAddress String?
  userAgent String?
  metadata  Json          @default("{}")
  createdAt DateTime      @default(now())

  @@index([orgId, createdAt])
  @@index([siteId, createdAt])
  @@index([projectId, createdAt])
  @@index([tokenId, createdAt])
  @@index([action, createdAt])
}
