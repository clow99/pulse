# Database
DATABASE_URL="postgresql://pulse:pulse_secret@localhost:5432/pulse?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (for Pulse AI Assistant)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Optional AI providers for Pulse AI Assistant (customer BYOK)
PULSE_AI_PROVIDER="openai"
PULSE_AI_MODEL=""
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"

# Agent/MCP access
# Streamable HTTP works at /api/mcp. Set REDIS_URL to enable legacy SSE at /api/sse.
PULSE_MCP_RESOURCE_URL=""
PULSE_AUTH_SERVER_URL=""
PULSE_MCP_VERBOSE_LOGS="false"
PULSE_SELF_ANALYTICS_SITE_TOKEN=""
REDIS_URL=""

# Uptime Monitoring (secret for cron-triggered uptime checks)
UPTIME_CHECK_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Proactive Insights (secret for cron-triggered insight generation)
INSIGHTS_CRON_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# SMTP Alerts (optional; enables email notification channels)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Pulse <alerts@example.com>"
